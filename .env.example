# Environment Configuration Example
# Copy this file to .env and update with your actual values

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/safety-monitoring

# Server Configuration
PORT=5000
NODE_ENV=development

# Session Secret (CHANGE IN PRODUCTION!)
SESSION_SECRET=safety-secret-key-2024-change-in-production

# Twilio SMS Configuration (DEPRECATED - Using Telegram instead)
# Sign up at https://www.twilio.com/ to get these credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram to get the token
# Run 'node scripts/get_telegram_chat_id.js' to get your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_MANAGER_CHAT_ID=your_telegram_chat_id_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Python Detection System Configuration (optional)
# These are read by the Python detection script

# API endpoint for sending violations
API_URL=http://localhost:5000/api/violations/detect

# Camera source: 0 for default webcam, or path to video file
CAMERA_SOURCE=0

# Detection interval in seconds (how often to run detection)
# Lower values = more frequent detection but higher CPU usage
# Recommended: 1.0 to 5.0 seconds
DETECTION_INTERVAL=1.0

# Alert cooldown in seconds (minimum time between alerts for same violation type)
# Prevents spam alerts when violation persists
# Recommended: 60 to 300 seconds (1-5 minutes)
ALERT_COOLDOWN=60.0
